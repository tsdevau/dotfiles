{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "dockerfile": {},
  "excludes": ["**/node_modules", "**/*-lock.json"],
  "graphql": {},
  "json": {
    "lineWidth": 120,
    "preferSingleLine": false,
    "trailingCommas": "never"
  },
  "jsonc": {
    "lineWidth": 120,
    "preferSingleLine": false,
    "trailingCommas": "never"
  },
  "malva": {},
  "markdown": {
    "emphasisKind": "underscores",
    "lineWidth": 120,
    "strongKind": "asterisks"
  },
  "markup_fmt": {
    "astro.scriptIndent": true,
    "astro.styleIndent": true,
    "astroAttrShorthand": true,
    "closingBracketSameLine": false,
    "closingTagLineBreakForEmpty": "always",
    "component.selfClosing": true,
    "formatComments": true,
    "html.normal.selfClosing": true,
    "html.scriptIndent": true,
    "html.styleIndent": true,
    "html.void.selfClosing": true,
    "indentWidth": 2,
    "mathml.selfClosing": true,
    "maxAttrsPerLine": 1,
    "printWidth": 120,
    "quotes": "double",
    "scriptIndent": true,
    "singleAttrsSameLine": true,
    "strictSvelteAttr": true,
    "styleIndent": true,
    "svelte.scriptIndent": true,
    "svelte.styleIndent": true,
    "svelteAttrShorthand": true,
    "svg.selfClosing": true,
    "useTabs": false,
    "vBindStyle": "long",
    "vOnStyle": "long",
    "vSlotStyle": "long",
    "vue.scriptIndent": true,
    "vue.styleIndent": true
  },
  "plugins": [
    "https://plugins.dprint.dev/typescript-0.95.15.wasm",
    "https://plugins.dprint.dev/json-0.21.3.wasm",
    "https://plugins.dprint.dev/markdown-0.21.1.wasm",
    "https://plugins.dprint.dev/toml-0.7.0.wasm",
    "https://plugins.dprint.dev/dockerfile-0.3.3.wasm",
    "https://plugins.dprint.dev/ruff-0.7.10.wasm",
    "https://plugins.dprint.dev/g-plane/malva-v0.15.3.wasm",
    "https://plugins.dprint.dev/g-plane/markup_fmt-v0.27.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_graphql-v0.2.3.wasm",
    "https://plugins.dprint.dev/RubixDev/stylua-v0.2.1.wasm"
  ],
  "ruff": {},
  "stylua": {
    "lineWidth": 120,
    "verify": true
  },
  "toml": {},
  "typescript": {
    "arrowFunction.useParentheses": "force",
    "commentLine.forceSpaceAfterSlashes": true,
    "indentWidth": 2,
    "jsx.bracketPosition": "nextLine",
    "jsx.multiLineParens": "prefer",
    "lineWidth": 120,
    "nextControlFlowPosition": "sameLine",
    "operatorPosition": "nextLine",
    "preferSingleLine": false,
    "quoteProps": "asNeeded",
    "quoteStyle": "alwaysDouble",
    "semiColons": "asi",
    "singleBodyPosition": "nextLine",
    "trailingCommas": "onlyMultiLine",
    "useBraces": "always",
    "useTabs": false
  },
  "indentWidth": 2,
  "lineWidth": 120,
  "newLineKind": "lf",
  "useTabs": false,
  "yaml": {
    "printWidth": 120
  }
}
